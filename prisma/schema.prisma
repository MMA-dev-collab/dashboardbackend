generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTH & RBAC
// ============================================

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  password       String
  firstName      String   @map("first_name")
  lastName       String   @map("last_name")
  profilePicture String?  @map("profile_picture") @db.LongText
  jobTitle       String?  @map("job_title")
  isActive       Boolean  @default(true) @map("is_active")
  paymentUsername String?  @map("payment_username")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Personal Growth
  totalXp              Int       @default(0) @map("total_xp")
  currentLevel         Int       @default(1) @map("current_level")
  dailyFreeTimeMinutes Int       @default(0) @map("daily_free_time_minutes")
  gamingTimeMinutes    Int       @default(0) @map("gaming_time_minutes")
  sleepTime            String?   @map("sleep_time")
  wakeTime             String?   @map("wake_time")
  timezone              String?              @map("timezone")
  totalGamingMinutes    Int       @default(120) @map("total_gaming_minutes")
  soloGamingMinutes     Int       @default(60)  @map("solo_gaming_minutes")
  collabGamingMinutes   Int       @default(60)  @map("collab_gaming_minutes")

  // Relations
  userRoles              UserRole[]
  refreshTokens          RefreshToken[]
  projectPartners        ProjectPartner[]
  wallet                 Wallet?
  withdrawalRequests     WithdrawalRequest[] @relation("WithdrawalRequester")
  processedRequests      WithdrawalRequest[] @relation("WithdrawalProcessor")
  auditLogs              AuditLog[]
  expenses               Expense[]
  leads                  Lead[]
  proposals              Proposal[]
  chatMessages           ChatMessage[]
  documents              Document[]
  knowledgeArticles      KnowledgeArticle[]
  decisionLogs           DecisionLog[]
  riskFlags              RiskFlag[]
  assignedTasks          Task[]              @relation("TaskAssignee")
  reportedTasks          Task[]              @relation("TaskReporter")
  taskComments           TaskComment[]
  taskAttachments        TaskAttachment[]
  commentMentions        CommentMention[]
  chatMentions           ChatMention[]
  receivedMessages       ChatMessage[]       @relation("DirectMessages")
  notifications          Notification[]      @relation("NotificationRecipient")
  triggeredNotifications Notification[]      @relation("NotificationActor")
  historyActions         TaskHistory[]       @relation("HistoryActor")
  createdEvents          Event[]             @relation("EventCreator")
  eventAttendances       EventAttendee[]
  aiConversations        AiConversation[]
  aiThreads              AiThread[]
  aiRequestLogs          AiRequestLog[]
  automationRules        AutomationRule[]
  devSessions            DevSession[]
  devSessionLogs         DevSessionLog[]
  forcedEndedSessions    DevSessionLog[]     @relation("ForceEndedBy")
  sprintMembers          SprintMember[]

  // Personal Growth relations
  growthTasks           GrowthTask[]
  schedules            Schedule[]
  gamingSessions       GamingSession[]
  xpLogs               XpLog[]
  streak               Streak?
  createdGrowthTeams   GrowthTeam[]
  teamMemberships      GrowthTeamMember[]
  sentFriendships      Friendship[]       @relation("FriendshipRequester")
  receivedFriendships  Friendship[]       @relation("FriendshipAddressee")
  availabilitySlots    AvailabilitySlot[]
  sentGrowthInvites    GrowthInvite[]     @relation("GrowthInviteInviter")
  receivedGrowthInvites GrowthInvite[]    @relation("GrowthInviteInvitee")
  routineCheckins RoutineCheckin[]
  dailySummaries  DailySummary[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  userRoles   UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model UserRole {
  id     String @id @default(uuid())
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Permission {
  id     String @id @default(uuid())
  module String
  action String

  rolePermissions RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique @db.VarChar(500)
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ============================================
// PROJECTS
// ============================================

model Project {
  id                String        @id @default(uuid())
  name              String
  clientName        String        @map("client_name")
  clientEmail       String?       @map("client_email")
  description       String?       @db.Text
  status            ProjectStatus @default(PLANNING)
  totalValue        Decimal       @default(0) @map("total_value") @db.Decimal(12, 2)
  companyPercentage Decimal       @default(30) @map("company_percentage") @db.Decimal(5, 2)
  paymentStatus     PaymentStatus @default(NOT_PAID) @map("payment_status")
  completionPct     Int           @default(0) @map("completion_pct")
  startDate         DateTime?     @map("start_date")
  endDate           DateTime?     @map("end_date")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  // Relations
  partners      ProjectPartner[]
  expenses      Expense[]
  payments      Payment[]
  milestones    Milestone[]
  documents     Document[]
  chatMessages  ChatMessage[]
  riskFlags     RiskFlag[]
  subscriptions Subscription[]
  proposals     Proposal[]
  decisionLogs  DecisionLog[]
  sprints       Sprint[]
  boardColumns  BoardColumn[]
  tasks         Task[]
  events        Event[]
  automationRules AutomationRule[]
  devSessions     DevSession[]
  devSessionLogs  DevSessionLog[]
  tags            Tag[]

  @@index([status])
  @@index([paymentStatus])
  @@map("projects")
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  NOT_PAID
  PARTIALLY_PAID
  FULLY_PAID
}

model ProjectPartner {
  id         String  @id @default(uuid())
  projectId  String  @map("project_id")
  userId     String  @map("user_id")
  percentage Decimal @map("percentage") @db.Decimal(5, 2)
  role       String  @default("contributor")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_partners")
}

model Milestone {
  id          String          @id @default(uuid())
  projectId   String          @map("project_id")
  title       String
  description String?         @db.Text
  status      MilestoneStatus @default(PENDING)
  dueDate     DateTime?       @map("due_date")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("milestones")
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

// ============================================
// FINANCE
// ============================================

model Payment {
  id        String        @id @default(uuid())
  projectId String        @map("project_id")
  amount    Decimal       @db.Decimal(12, 2)
  method    PaymentMethod @default(BANK_TRANSFER)
  note      String?       @db.Text
  paidAt    DateTime      @default(now()) @map("paid_at")
  createdAt DateTime      @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("payments")
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  ONLINE
  OTHER
}

model Expense {
  id          String          @id @default(uuid())
  projectId   String?         @map("project_id")
  userId      String          @map("user_id")
  category    ExpenseCategory @default(OTHER)
  description String          @db.Text
  amount      Decimal         @db.Decimal(12, 2)
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user    User     @relation(fields: [userId], references: [id])

  @@index([projectId])
  @@index([category])
  @@map("expenses")
}

enum ExpenseCategory {
  SOFTWARE
  HARDWARE
  HOSTING
  MARKETING
  SALARY
  OFFICE
  TRAVEL
  OTHER
}

// ============================================
// WALLET & WITHDRAWALS
// ============================================

model Wallet {
  id               String  @id @default(uuid())
  userId           String  @unique @map("user_id")
  totalEarned      Decimal @default(0) @map("total_earned") @db.Decimal(12, 2)
  pendingBalance   Decimal @default(0) @map("pending_balance") @db.Decimal(12, 2)
  availableBalance Decimal @default(0) @map("available_balance") @db.Decimal(12, 2)
  totalWithdrawn   Decimal @default(0) @map("total_withdrawn") @db.Decimal(12, 2)

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id           String                @id @default(uuid())
  walletId     String                @map("wallet_id")
  type         WalletTransactionType
  amount       Decimal               @db.Decimal(12, 2)
  balanceAfter Decimal               @map("balance_after") @db.Decimal(12, 2)
  description  String                @db.Text
  referenceId  String?               @map("reference_id")
  createdAt    DateTime              @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([type])
  @@index([createdAt])
  @@map("wallet_transactions")
}

enum WalletTransactionType {
  EARNING
  WITHDRAWAL
  ADJUSTMENT
  PENDING_TO_AVAILABLE
}

model WithdrawalRequest {
  id              String           @id @default(uuid())
  userId          String           @map("user_id")
  amount          Decimal          @db.Decimal(12, 2)
  status          WithdrawalStatus @default(PENDING)
  note            String?          @db.Text
  receiptPath     String?          @map("receipt_path")
  receiptFileName String?          @map("receipt_file_name")
  receiptMimeType String?          @map("receipt_mime_type")
  verifiedAmount  Decimal?         @map("verified_amount") @db.Decimal(12, 2)
  transactionId   String?          @unique @map("transaction_id")
  processedBy     String?          @map("processed_by")
  processedAt     DateTime?        @map("processed_at")
  rejectReason    String?          @map("reject_reason") @db.Text
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  user      User  @relation("WithdrawalRequester", fields: [userId], references: [id])
  processor User? @relation("WithdrawalProcessor", fields: [processedBy], references: [id])

  @@index([userId])
  @@index([status])
  @@map("withdrawal_requests")
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================
// CRM
// ============================================

model Lead {
  id            String    @id @default(uuid())
  companyName   String    @map("company_name")
  contactName   String    @map("contact_name")
  email         String?
  phone         String?
  source        String?
  stage         LeadStage @default(NEW)
  expectedValue Decimal?  @map("expected_value") @db.Decimal(12, 2)
  notes         String?   @db.Text
  assignedTo    String?   @map("assigned_to")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  assignee  User?      @relation(fields: [assignedTo], references: [id])
  proposals Proposal[]

  @@index([stage])
  @@map("leads")
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

// ============================================
// PROPOSALS
// ============================================

model Proposal {
  id          String         @id @default(uuid())
  leadId      String?        @map("lead_id")
  projectId   String?        @map("project_id")
  title       String
  clientName  String         @map("client_name")
  status      ProposalStatus @default(DRAFT)
  totalAmount Decimal        @default(0) @map("total_amount") @db.Decimal(12, 2)
  validUntil  DateTime?      @map("valid_until")
  content     Json?
  createdBy   String         @map("created_by")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  lead    Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  creator User     @relation(fields: [createdBy], references: [id])

  @@index([leadId])
  @@index([projectId])
  @@map("proposals")
}

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

// ============================================
// SUBSCRIPTIONS & RETAINERS
// ============================================

model Subscription {
  id          String             @id @default(uuid())
  clientName  String             @map("client_name")
  serviceName String             @map("service_name")
  projectId   String?            @map("project_id")
  amount      Decimal            @db.Decimal(12, 2)
  frequency   SubscriptionFreq   @default(MONTHLY)
  status      SubscriptionStatus @default(ACTIVE)
  startDate   DateTime           @map("start_date")
  nextRenewal DateTime           @map("next_renewal")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  project  Project?              @relation(fields: [projectId], references: [id], onDelete: SetNull)
  invoices SubscriptionInvoice[]

  @@index([projectId])
  @@map("subscriptions")
}

enum SubscriptionFreq {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

model SubscriptionInvoice {
  id             String        @id @default(uuid())
  subscriptionId String        @map("subscription_id")
  amount         Decimal       @db.Decimal(12, 2)
  issueDate      DateTime      @default(now()) @map("issue_date")
  dueDate        DateTime      @map("due_date")
  status         InvoiceStatus @default(UNPAID)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@map("subscription_invoices")
}

enum InvoiceStatus {
  UNPAID
  PAID
  OVERDUE
  CANCELLED
}

// ============================================
// DOCUMENTS
// ============================================

model Document {
  id          String   @id @default(uuid())
  projectId   String?  @map("project_id")
  fileName    String   @map("file_name")
  filePath    String   @map("file_path")
  fileSize    Int      @map("file_size")
  mimeType    String   @map("mime_type")
  category    String   @default("general")
  description String?  @db.Text
  version     Int      @default(1)
  uploadedBy  String   @map("uploaded_by")
  createdAt   DateTime @default(now()) @map("created_at")

  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  uploader User     @relation(fields: [uploadedBy], references: [id])

  @@index([projectId])
  @@map("documents")
}

// ============================================
// CHAT
// ============================================

model ChatMessage {
  id         String   @id @default(uuid())
  projectId  String?  @map("project_id")
  userId     String   @map("user_id") // Sender
  receiverId String?  @map("receiver_id") // Optional DM receiver
  content    String   @db.Text
  type       String   @default("text")
  createdAt  DateTime @default(now()) @map("created_at")

  project  Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])
  receiver User?    @relation("DirectMessages", fields: [receiverId], references: [id], onDelete: SetNull)

  mentions ChatMention[]

  @@index([projectId])
  @@index([receiverId])
  @@index([createdAt])
  @@map("chat_messages")
}

model ChatMention {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([userId])
  @@map("chat_mentions")
}

// ============================================
// KNOWLEDGE BASE
// ============================================

model KnowledgeArticle {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.LongText
  category  String   @default("general")
  tags      String?  @db.Text
  authorId  String   @map("author_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  author User @relation(fields: [authorId], references: [id])

  @@map("knowledge_articles")
}

// ============================================
// DECISION LOG
// ============================================

model DecisionLog {
  id          String   @id @default(uuid())
  projectId   String?  @map("project_id")
  title       String
  description String   @db.Text
  context     String?  @db.Text
  outcome     String?  @db.Text
  authorId    String   @map("author_id")
  createdAt   DateTime @default(now()) @map("created_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  author  User     @relation(fields: [authorId], references: [id])

  @@index([projectId])
  @@map("decision_logs")
}

// ============================================
// RISK FLAGS
// ============================================

model RiskFlag {
  id          String       @id @default(uuid())
  projectId   String?      @map("project_id")
  type        RiskType
  severity    RiskSeverity @default(MEDIUM)
  title       String
  description String?      @db.Text
  isResolved  Boolean      @default(false) @map("is_resolved")
  reportedBy  String       @map("reported_by")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  reporter User     @relation(fields: [reportedBy], references: [id])

  @@index([projectId])
  @@index([severity])
  @@map("risk_flags")
}

enum RiskType {
  LATE_PAYMENT
  SCOPE_CREEP
  BUDGET_OVERRUN
  RESOURCE_ISSUE
  TECHNICAL_DEBT
  CLIENT_ISSUE
  OTHER
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  module     String
  entityId   String?  @map("entity_id")
  entityType String?  @map("entity_type")
  oldData    Json?    @map("old_data")
  newData    Json?    @map("new_data")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([module])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// COMPANY CONFIG
// ============================================

model CompanyConfig {
  id    String @id @default(uuid())
  key   String @unique
  value String @db.Text

  @@map("company_config")
}

// ============================================
// AGILE & JIRA
// ============================================

model Sprint {
  id          String       @id @default(uuid())
  projectId   String       @map("project_id")
  name        String
  goal        String?      @db.Text
  totalPoints Int          @default(0) @map("total_points")
  status      SprintStatus @default(PLANNED)
  startDate   DateTime?    @map("start_date")
  endDate     DateTime?    @map("end_date")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  project    Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks      Task[]
  milestones SprintMilestone[]
  budget     SprintBudget?
  members    SprintMember[]

  @@index([projectId])
  @@index([status])
  @@map("sprints")
}

model SprintMember {
  id       String @id @default(uuid())
  sprintId String @map("sprint_id")
  userId   String @map("user_id")
  role     String @default("developer")

  sprint Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sprintId, userId])
  @@index([sprintId])
  @@map("sprint_members")
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

model BoardColumn {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("board_columns")
}

model Task {
  id            String       @id @default(uuid())
  projectId     String       @map("project_id")
  sprintId      String?      @map("sprint_id")
  columnId      String       @map("column_id")
  title         String
  description   String?      @db.Text
  type          TaskType     @default(TASK)
  priority      TaskPriority @default(MEDIUM)
  storyPoints   Int          @default(0) @map("story_points")
  estimatedTime Int          @default(0) @map("estimated_time") // in minutes
  loggedTime    Int          @default(0) @map("logged_time")    // in minutes
  dueDate       DateTime?    @map("due_date")
  parentId      String?      @map("parent_id")
  assigneeId    String?      @map("assignee_id")
  reporterId    String       @map("reporter_id")
  isArchived    Boolean      @default(false) @map("is_archived")
  version       Int          @default(1)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint      Sprint?          @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  column      BoardColumn      @relation(fields: [columnId], references: [id])
  parent      Task?            @relation("SubTasks", fields: [parentId], references: [id], onDelete: Cascade)
  subTasks    Task[]           @relation("SubTasks")
  assignee    User?            @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter    User             @relation("TaskReporter", fields: [reporterId], references: [id])
  comments    TaskComment[]
  history     TaskHistory[]
  attachments TaskAttachment[]
  devSessions DevSession[]
  taskTags    TaskTag[]

  @@index([projectId])
  @@index([sprintId])
  @@index([columnId])
  @@index([assigneeId])
  @@index([parentId])
  @@map("tasks")
}

model Tag {
  id        String    @id @default(uuid())
  projectId String    @map("project_id")
  name      String
  color     String    @default("#6366f1")
  createdAt DateTime  @default(now()) @map("created_at")

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskTags TaskTag[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("tags")
}

model TaskTag {
  id     String @id @default(uuid())
  taskId String @map("task_id")
  tagId  String @map("tag_id")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([taskId, tagId])
  @@index([taskId])
  @@map("task_tags")
}

enum TaskType {
  STORY
  TASK
  BUG
  EPIC
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  authorId  String   @map("author_id")
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  task     Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author   User             @relation(fields: [authorId], references: [id])
  mentions CommentMention[]

  @@index([taskId])
  @@map("task_comments")
}

model TaskHistory {
  id           String   @id @default(uuid())
  taskId       String   @map("task_id")
  fromColumnId String?  @map("from_column_id")
  toColumnId   String?  @map("to_column_id")
  fromStatus   String?  @map("from_status")
  toStatus     String?  @map("to_status")
  movedBy      String   @map("moved_by")
  movedAt      DateTime @default(now()) @map("moved_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation("HistoryActor", fields: [movedBy], references: [id])

  @@index([taskId])
  @@map("task_history")
}

model TaskAttachment {
  id         String   @id @default(uuid())
  taskId     String   @map("task_id")
  url        String   @db.Text
  fileName   String   @map("file_name")
  uploadedBy String   @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at")

  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploader User @relation(fields: [uploadedBy], references: [id])

  @@index([taskId])
  @@map("task_attachments")
}

model CommentMention {
  id        String   @id @default(uuid())
  commentId String   @map("comment_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  comment TaskComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@map("comment_mentions")
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  message   String   @db.Text
  link      String?  @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  type      String   @default("info") // 'info', 'success', 'warning', 'error', 'task', 'chat'
  actorId   String?  @map("actor_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  // Composite index: covers the most common query pattern (list unread for user, ordered by date)
  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

// ============================================
// CALENDAR & EVENTS
// ============================================

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  allDay      Boolean  @default(false) @map("all_day")
  color       String? // Hex color for calendar rendering
  type        String   @default("meeting") // meeting, deadline, milestone
  projectId   String?  @map("project_id")
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project   Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  creator   User            @relation("EventCreator", fields: [createdBy], references: [id])
  attendees EventAttendee[]

  @@index([startDate, endDate])
  @@index([createdBy])
  @@map("events")
}

model EventAttendee {
  id      String @id @default(uuid())
  eventId String @map("event_id")
  userId  String @map("user_id")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("event_attendees")
}

// ============================================
// AI ASSISTANT
// ============================================

model AiThread {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String? // Optional title, can be first message snippet
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations AiConversation[]

  @@index([userId, updatedAt])
  @@map("ai_threads")
}

model AiConversation {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  threadId  String?  @map("thread_id")
  role      String // 'user', 'assistant', 'tool'
  content   String   @db.Text
  metadata  String?  @db.Text // JSON: provider, model, tools called, latency
  createdAt DateTime @default(now()) @map("created_at")

  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread AiThread? @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([threadId])
  // Composite index: covers thread-scoped history queries (userId + threadId + order by createdAt)
  @@index([userId, threadId, createdAt])
  @@map("ai_conversations")
}

model AiRequestLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  provider  String // 'openrouter'
  model     String // model identifier
  toolsUsed String?  @db.Text // JSON array of tool names
  latencyMs Int      @map("latency_ms")
  success   Boolean
  error     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([provider])
  @@map("ai_request_logs")
}

// ============================================
// WORKFLOW AUTOMATION
// ============================================

model AutomationRule {
  id          String           @id @default(uuid())
  name        String
  description String?          @db.Text
  triggerEvent AutomationTrigger
  conditions  Json?            // JSON: field, operator, value
  actions     Json             // JSON array: { type, config }
  isActive    Boolean          @default(true) @map("is_active")
  projectId   String?          @map("project_id")
  createdBy   String           @map("created_by")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  project Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  creator User                 @relation(fields: [createdBy], references: [id])
  logs    AutomationLog[]

  @@index([triggerEvent])
  @@index([isActive])
  @@map("automation_rules")
}

enum AutomationTrigger {
  PROJECT_CREATED
  PROJECT_STATUS_CHANGED
  PAYMENT_RECEIVED
  TASK_CREATED
  TASK_COMPLETED
  SPRINT_STARTED
  SPRINT_COMPLETED
  LEAD_CREATED
  LEAD_STAGE_CHANGED
  WITHDRAWAL_REQUESTED
}

model AutomationLog {
  id          String        @id @default(uuid())
  ruleId      String        @map("rule_id")
  triggerData Json?         @map("trigger_data")
  result      Json?         // { success, actionsRun, errors }
  executedAt  DateTime      @default(now()) @map("executed_at")

  rule AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([executedAt])
  @@map("automation_logs")
}

// ============================================
// SPRINT ENHANCEMENTS
// ============================================

model SprintMilestone {
  id          String       @id @default(uuid())
  sprintId    String       @map("sprint_id")
  title       String
  description String?      @db.Text
  dueDate     DateTime?    @map("due_date")
  status      MilestoneStatus @default(PENDING)
  order       Int          @default(0)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  sprint Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  @@index([sprintId])
  @@map("sprint_milestones")
}

model SprintBudget {
  id          String   @id @default(uuid())
  sprintId    String   @unique @map("sprint_id")
  plannedBudget Decimal @default(0) @map("planned_budget") @db.Decimal(12, 2)
  actualCost  Decimal  @default(0) @map("actual_cost") @db.Decimal(12, 2)
  updatedAt   DateTime @updatedAt @map("updated_at")

  sprint Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  @@map("sprint_budgets")
}

// ============================================
// DEVELOPER ACTIVITY TRACKING
// ============================================

model DevSession {
  id                String   @id @default(uuid())
  projectId         String   @map("project_id")
  userId            String   @map("user_id")
  taskId            String?  @map("task_id")
  isActive          Boolean  @default(true) @map("is_active")
  activeStartedAt   DateTime @default(now()) @map("active_started_at")
  lastHeartbeatAt   DateTime @default(now()) @map("last_heartbeat_at")
  currentTask       String?  @map("current_task") @db.Text
  workingOnBranch   String?  @map("working_on_branch")
  endedAt           DateTime? @map("ended_at")
  pausedAt          DateTime? @map("paused_at")
  totalPausedMs     Int      @default(0) @map("total_paused_ms")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  task    Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([projectId, isActive])
  @@index([userId, isActive])
  @@index([lastHeartbeatAt])
  @@map("dev_sessions")
}

model DevSessionLog {
  id                  String    @id @default(uuid())
  projectId           String    @map("project_id")
  userId              String    @map("user_id")
  taskId              String?   @map("task_id")
  branch              String?
  startedAt           DateTime  @map("started_at")
  endedAt             DateTime  @map("ended_at")
  pushedCode          Boolean   @default(false) @map("pushed_code")
  changesDescription  String?   @map("changes_description") @db.Text
  requiresPull        Boolean   @default(false) @map("requires_pull")
  forceEndedBy        String?   @map("force_ended_by")
  forceEndedAt        DateTime? @map("force_ended_at")

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  forceEnder  User?   @relation("ForceEndedBy", fields: [forceEndedBy], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([userId])
  @@index([startedAt])
  @@map("dev_session_logs")
}

// ============================================
// PERSONAL GROWTH SYSTEM
// ============================================

model GrowthTask {
  id                     String              @id @default(uuid())
  userId                 String              @map("user_id")
  title                  String
  description            String?             @db.Text
  duration               Int                 @map("duration")
  priority               GrowthTaskPriority  @default(MEDIUM)
  xpReward               Int                 @default(0) @map("xp_reward")
  status                 GrowthTaskStatus    @default(PENDING)
  taskType               GrowthTaskType      @default(FLEXIBLE)
  isCarryOver            Boolean             @default(false) @map("is_carry_over")
  carryOverFrom          DateTime?           @map("carry_over_from")
  scheduledDate          DateTime?           @map("scheduled_date") @db.Date
  scheduledTime          DateTime?           @map("scheduled_time")
  dueDate                DateTime?           @map("due_date")
  completedAt            DateTime?           @map("completed_at")
  focusBlocksCompleted   Int                 @default(0) @map("focus_blocks_completed")
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  scheduleBlocks ScheduleBlock[]

  @@index([userId])
  @@index([status])
  @@index([scheduledDate])
  @@index([userId, status])
  @@map("growth_tasks")
}

enum GrowthTaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum GrowthTaskStatus {
  PENDING
  ACTIVE
  COMPLETED
  OVERDUE
}

enum GrowthTaskType {
  FIXED
  FLEXIBLE
}

model Schedule {
  id                  String   @id @default(uuid())
  userId              String   @map("user_id")
  date                DateTime @db.Date @map("date")
  totalFreeTime       Int      @default(0) @map("total_free_time")
  totalScheduledTime  Int      @default(0) @map("total_scheduled_time")
  gamingMinutes       Int?     @map("gaming_minutes")
  soloMinutes         Int?     @map("solo_minutes")
  collabMinutes       Int?     @map("collab_minutes")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  blocks ScheduleBlock[]

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("schedules")
}

model ScheduleBlock {
  id          String              @id @default(uuid())
  scheduleId  String              @map("schedule_id")
  growthTaskId String?            @map("growth_task_id")
  title       String
  blockType   ScheduleBlockType   @default(TASK)
  startTime   DateTime            @map("start_time")
  endTime     DateTime            @map("end_time")
  duration    Int
  status      ScheduleBlockStatus @default(PENDING)
  color       String?
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  schedule   Schedule    @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  growthTask GrowthTask? @relation(fields: [growthTaskId], references: [id], onDelete: SetNull)

  @@index([scheduleId])
  @@index([growthTaskId])
  @@index([startTime, endTime])
  @@map("schedule_blocks")
}

enum ScheduleBlockType {
  TASK
  FIXED_EVENT
  GAMING
  FOCUS_BLOCK
  BREAK
}

enum ScheduleBlockStatus {
  PENDING
  ACTIVE
  COMPLETED
}

model GamingSession {
  id              String              @id @default(uuid())
  userId          String              @map("user_id")
  sessionType     GamingSessionType   @default(SOLO)
  teamId          String?             @map("team_id")
  startTime       DateTime            @map("start_time")
  endTime         DateTime?           @map("end_time")
  plannedDuration Int                 @default(0) @map("planned_duration")
  actualDuration  Int                 @default(0) @map("actual_duration")
  startedAt       DateTime?           @map("started_at")
  endedAt         DateTime?           @map("ended_at")
  status          GamingSessionStatus @default(SCHEDULED)
  isLocked        Boolean             @default(false) @map("is_locked")
  lockReason      String?            @map("lock_reason") @db.Text
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  team GrowthTeam? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([startTime])
  @@map("gaming_sessions")
}

enum GamingSessionType {
  SOLO
  TEAM
}

enum GamingSessionStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

model XpLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  amount      Int
  source      XpSource
  referenceId String?  @map("reference_id")
  multiplier  Float    @default(1.0)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([source])
  @@index([createdAt])
  @@map("xp_logs")
}

enum XpSource {
  TASK_COMPLETION
  FOCUS_BLOCK
  ROUTINE
  STREAK_BONUS
  WELLNESS
  PENALTY
  GAMING
  TEAM_PARTICIPATION
}

model Streak {
  id              String    @id @default(uuid())
  userId          String    @unique @map("user_id")
  currentStreak   Int       @default(0) @map("current_streak")
  longestStreak   Int       @default(0) @map("longest_streak")
  lastActiveDate  DateTime? @map("last_active_date") @db.Date
  multiplier      Float     @default(1.0)
  sleepStreak        Int      @default(0) @map("sleep_streak")
  longestSleepStreak Int      @default(0) @map("longest_sleep_streak")
  lastSleepCheckin   DateTime?            @map("last_sleep_checkin")
  wakeStreak         Int      @default(0) @map("wake_streak")
  longestWakeStreak  Int      @default(0) @map("longest_wake_streak")
  lastWakeCheckin    DateTime?            @map("last_wake_checkin")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streaks")
}

model GrowthTeam {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  creator  User              @relation(fields: [createdBy], references: [id])
  members  GrowthTeamMember[]
  invites  GrowthInvite[]
  gamingSessions GamingSession[]

  @@index([createdBy])
  @@map("growth_teams")
}

model GrowthTeamMember {
  id     String @id @default(uuid())
  teamId String @map("team_id")
  userId String @map("user_id")
  role   String @default("member")

  team GrowthTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@map("growth_team_members")
}

model Friendship {
  id          String            @id @default(uuid())
  requesterId String            @map("requester_id")
  addresseeId String            @map("addressee_id")
  status      FriendshipStatus  @default(PENDING)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([requesterId])
  @@index([addresseeId])
  @@index([status])
  @@map("friendships")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

model AvailabilitySlot {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  dayOfWeek    Int       @map("day_of_week")
  startTime    String    @map("start_time")
  endTime      String    @map("end_time")
  isRecurring  Boolean   @default(true) @map("is_recurring")
  specificDate DateTime? @map("specific_date") @db.Date
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([dayOfWeek])
  @@map("availability_slots")
}

model GrowthInvite {
  id         String             @id @default(uuid())
  teamId     String?            @map("team_id")
  sessionId  String?            @map("session_id")
  inviterId  String             @map("inviter_id")
  inviteeId  String             @map("invitee_id")
  type       GrowthInviteType   @default(TEAM)
  status     GrowthInviteStatus @default(PENDING)
  message    String?            @db.Text
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  team    GrowthTeam? @relation(fields: [teamId], references: [id], onDelete: Cascade)
  inviter User       @relation("GrowthInviteInviter", fields: [inviterId], references: [id])
  invitee User       @relation("GrowthInviteInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([inviteeId])
  @@index([status])
  @@map("growth_invites")
}

enum GrowthInviteType {
  TEAM
  SESSION
}

enum GrowthInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

model RoutineCheckin {
  id               String             @id @default(uuid())
  userId           String             @map("user_id")
  type             RoutineCheckinType
  checkinAt        DateTime           @map("checkin_at")
  isOnTime         Boolean            @map("is_on_time")
  deviationMinutes Int                @map("deviation_minutes")
  date             DateTime           @db.Date @map("date")
  createdAt        DateTime           @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, date])
  @@index([userId])
  @@index([date])
  @@map("routine_checkins")
}

enum RoutineCheckinType {
  SLEEP
  WAKE
}

model DailySummary {
  id                 String   @id @default(uuid())
  userId             String   @map("user_id")
  date               DateTime @db.Date @map("date")
  baseGamingMinutes  Int      @default(0) @map("base_gaming_minutes")
  penaltyMinutes     Int      @default(0) @map("penalty_minutes")
  bonusMinutes       Int      @default(0) @map("bonus_minutes")
  finalGamingMinutes Int      @default(0) @map("final_gaming_minutes")
  soloMinutes        Int      @default(0) @map("solo_minutes")
  collabMinutes      Int      @default(0) @map("collab_minutes")
  overduePenalty     Int      @default(0) @map("overdue_penalty")
  carryOverPenalty   Int      @default(0) @map("carry_over_penalty")
  lateSleepPenalty   Int      @default(0) @map("late_sleep_penalty")
  missedWakePenalty  Int      @default(0) @map("missed_wake_penalty")
  completedTaskBonus Int      @default(0) @map("completed_task_bonus")
  streakBonus        Int      @default(0) @map("streak_bonus")
  onTimeSleepBonus   Int      @default(0) @map("on_time_sleep_bonus")
  onTimeWakeBonus    Int      @default(0) @map("on_time_wake_bonus")
  sleepCheckedIn     Boolean  @default(false) @map("sleep_checked_in")
  wakeCheckedIn      Boolean  @default(false) @map("wake_checked_in")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("daily_summaries")
}
