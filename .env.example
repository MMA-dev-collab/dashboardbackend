# Server
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Company
COMPANY_RESERVE_AMOUNT=5000

# Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
