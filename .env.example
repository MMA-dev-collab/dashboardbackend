# Database
DATABASE_URL="mysql://root:password@localhost:3306/egycodera"

# JWT
JWT_SECRET="change-this-to-a-secure-random-string"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_SECRET="change-this-to-another-secure-random-string"
